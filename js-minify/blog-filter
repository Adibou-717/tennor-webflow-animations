document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.blog_category_tab-button');
    const items = document.querySelectorAll('.blogpost_collection-item');
    const fadeDuration = 300; // Durée du fondu en millisecondes
    let isAnimating = false;

    // Initialisation de la transition CSS sur tous les items
    items.forEach(item => {
        item.style.transition = `opacity ${fadeDuration}ms ease`;
    });

    function normalizeText(str) {
        if (!str) return "";
        return str.normalize("NFD")
                  .replace(/[\u0300-\u036f]/g, "") // Supprime les accents
                  .trim()
                  .toLowerCase();
    }

    function filterPosts(categoryName, isInitialLoad = false) {
        if (isAnimating) return;
        isAnimating = true;

        const filterText = normalizeText(categoryName);
        const delay = isInitialLoad ? 0 : fadeDuration;

        // ÉTAPE 1 : Fade out de tous les éléments actuellement visibles
        if (!isInitialLoad) {
            items.forEach(item => {
                if (item.style.display !== 'none') {
                    item.style.opacity = '0';
                }
            });
        }

        // ÉTAPE 2 : Attendre que le fade out soit terminé, puis changer le display
        setTimeout(() => {
            const itemsToShow = [];

            items.forEach(item => {
                const tagElements = item.querySelectorAll('.title-tag-09 .bagoss-16, .title-tag-09 .bagoss-16.reset-class');
                let isMatch = false;
                
                tagElements.forEach(tag => {
                    if (tag && normalizeText(tag.textContent) === filterText) {
                        isMatch = true;
                    }
                });
                
                if (isMatch) {
                    item.style.display = ''; // Remet l'élément dans le flux
                    if (!isInitialLoad) item.style.opacity = '0'; // Le garde invisible pour préparer le fade in
                    itemsToShow.push(item);
                } else {
                    item.style.display = 'none'; // Le sort du flux
                    item.style.opacity = '0';
                }
            });

            // Force le navigateur à prendre en compte le changement de display avant l'opacité (Reflow)
            document.body.offsetHeight;

            // ÉTAPE 3 : Fade in des nouveaux éléments
            itemsToShow.forEach(item => {
                item.style.opacity = '1';
            });

            // Libère le filtre à la fin de l'animation
            setTimeout(() => {
                isAnimating = false;
            }, delay);

        }, delay);
    }

    // Ajout de l'événement de clic sur chaque bouton
    buttons.forEach(button => {
        button.addEventListener('click', function(e) {
            e.preventDefault(); 
            
            // Empêche de relancer si l'animation est en cours ou si on clique sur la catégorie déjà active
            if (isAnimating || this.classList.contains('current')) return;
            
            // Retrait de la classe .current partout
            buttons.forEach(btn => {
                btn.classList.remove('current');
                const icon = btn.querySelector('.icon-075');
                if (icon) icon.classList.remove('current');
            });
            
            // Ajout de la classe au bouton cliqué et à son icône
            this.classList.add('current');
            const currentIcon = this.querySelector('.icon-075');
            if (currentIcon) currentIcon.classList.add('current');
            
            // Lancement du filtre
            filterPosts(this.textContent);
        });
    });

    // Initialisation au chargement de la page
    const defaultActiveButton = document.querySelector('.blog_category_tab-button.current');
    if (defaultActiveButton) {
        const defaultIcon = defaultActiveButton.querySelector('.icon-075');
        if (defaultIcon) defaultIcon.classList.add('current');
        
        // true en second paramètre pour éviter l'effet fade-out au chargement initial
        filterPosts(defaultActiveButton.textContent, true);
    }
});
